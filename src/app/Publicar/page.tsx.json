"use client";

import { useState, useMemo, useRef } from "react";
import { Card } from "@/components/ui/card";
import { SidebarProvider } from "@/components/ui/sidebar";
import { Input } from "@/components/ui/input";
import { Textarea } from "@/components/ui/textarea";
import { ChevronRight, ArrowLeft, Bell, UserCircle, PlusCircle, Camera, ImagePlus, RefreshCcw } from "lucide-react";
import Image from "next/image";
import Link from "next/link";

import baseDataRaw from "@/lib/base_hotcars.json";
const baseData = baseDataRaw as any;

const ALL_LOGO_BRANDS = [
  { name: "Volkswagen", logo: "/marcas/volkswagen.png" },
  { name: "Ford", logo: "/marcas/ford.png" },
  { name: "Fiat", logo: "/marcas/fiat.png" },
  { name: "Toyota", logo: "/marcas/toyota.png" },
  { name: "Peugeot", logo: "/marcas/peugeot.png" },
  { name: "Chevrolet", logo: "/marcas/chevrolet.png" },
  { name: "BMW", logo: "/marcas/bmw.png" },
  { name: "Mercedes-Benz", logo: "/marcas/mercedes-benz.png" },
  { name: "Renault", logo: "/marcas/Renault.png" },
  { name: "Jeep", logo: "/marcas/jeep.png" },
  { name: "Audi", logo: "/marcas/audi.png" },
];

const categories = [
  { name: "Auto", icon: "/img/auto.png" },
  { name: "Pickup", icon: "/img/pickup.png" },
  { name: "Utilitario", icon: "/img/utilitario.png" },
  { name: "SUV", icon: "/img/suv.png" },
  { name: "Moto", icon: "/img/moto.png" },
  { name: "Camion", icon: "/img/camion.png" },
];

const YEARS = Array.from({ length: 40 }, (_, i) => (2026 - i).toString());

export default function PublishPage() {
  const [step, setStep] = useState(1); 
  const [selectedCategory, setSelectedCategory] = useState("");
  const [selectedBrand, setSelectedBrand] = useState("");
  const [selectedModel, setSelectedModel] = useState("");
  const [selectedYear, setSelectedYear] = useState("");
  const [selectedVersion, setSelectedVersion] = useState("");
  
  const [showManualBox, setShowManualBox] = useState(false);
  const [searchBrand, setSearchBrand] = useState("");
  const [searchModel, setSearchModel] = useState("");
  const [searchVersion, setSearchVersion] = useState("");
  const [km, setKm] = useState("");

  const yearSectionRef = useRef<HTMLDivElement>(null);
  const versionSectionRef = useRef<HTMLDivElement>(null);
  const reviewSectionRef = useRef<HTMLDivElement>(null);
  const kmSectionRef = useRef<HTMLDivElement>(null);

  const availableBrands = useMemo(() => {
    if (!selectedCategory || !baseData) return [];
    return Object.keys(baseData[selectedCategory.toUpperCase()] || {}).sort();
  }, [selectedCategory]);

  const dynamicTopBrands = useMemo(() => {
    return ALL_LOGO_BRANDS.filter(brand => 
      availableBrands.some(b => 
        b.toUpperCase().replace(/-/g, ' ').includes(brand.name.toUpperCase().replace(/-/g, ' ').split(' ')[0])
      )
    );
  }, [availableBrands]);

  const availableModels = useMemo(() => {
    if (!selectedCategory || !selectedBrand || !baseData) return [];
    return Object.keys(baseData[selectedCategory.toUpperCase()]?.[selectedBrand] || {}).sort();
  }, [selectedCategory, selectedBrand]);

  const availableVersions = useMemo(() => {
    if (!selectedCategory || !selectedBrand || !selectedModel || !baseData) return [];
    return (baseData[selectedCategory.toUpperCase()]?.[selectedBrand]?.[selectedModel] || []).sort();
  }, [selectedCategory, selectedBrand, selectedModel]);

  const scrollTo = (ref: React.RefObject<HTMLDivElement>) => {
    setTimeout(() => { ref.current?.scrollIntoView({ behavior: "smooth", block: "start" }); }, 100);
  };

  const handleKmChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    const value = e.target.value.replace(/\D/g, "");
    const formatted = value.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    setKm(formatted);
  };

  const resetAll = () => {
    setStep(1);
    setSelectedCategory("");
    setSelectedBrand("");
    setSelectedModel("");
    setSelectedYear("");
    setSelectedVersion("");
    setShowManualBox(false);
    setKm("");
  };

  const inputClassName = "h-11 bg-gray-50 uppercase font-bold !text-black border-gray-200 focus:!border-[#00984a] focus:!ring-0 focus-visible:!ring-0 focus-visible:!border-[#00984a] outline-none transition-all border shadow-none";
  const manualInputClass = "h-12 bg-[#f4f6f8] border-none font-bold uppercase text-gray-800 focus-visible:ring-1 focus-visible:ring-[#00984a] shadow-none";

  return (
    <SidebarProvider defaultOpen={false}>
      <div className="flex min-h-screen w-full flex-col font-sans" style={{ backgroundColor: "#f0f2f5" }}>
        
        <header className="h-14 md:h-16 flex items-center justify-between px-4 md:px-6 z-50 shadow-md sticky top-0" style={{ backgroundColor: "#0f1c23" }}>
          <Link href="/dashboard"><Image src="/logo.png" alt="Hotcars" width={100} height={30} className="object-contain" priority /></Link>
        </header>

        <main className="flex-1 overflow-y-auto pb-20">
          
          {step === 1 && (
            <div className="animate-in fade-in duration-500">
              <div className="w-full h-64 md:h-72 flex flex-col pt-16 md:pt-20 items-center text-center px-6" style={{ backgroundColor: "#00984a" }}>
                <h1 className="text-2xl md:text-4xl font-medium text-white mb-2 tracking-tight">Empecemos a trabajar!</h1>
                <p className="text-base md:text-xl font-medium text-white opacity-95 tracking-tight">¿Qué tipo de unidad vas a publicar hoy?</p>
              </div>
              <div className="p-4 md:p-6 -mt-24 md:-mt-28">
                <div className="grid grid-cols-2 md:grid-cols-6 gap-3 md:gap-5 max-w-5xl mx-auto">
                  {categories.map((cat) => (
                    <Card key={cat.name} className="cursor-pointer bg-white rounded-xl flex flex-col items-center justify-between p-5 aspect-square border-none shadow-lg active:scale-95" 
                      onClick={() => { setSelectedCategory(cat.name); setStep(2); }}>
                      <div className="flex-1 flex items-center justify-center w-full"><div className="relative w-10 h-10 md:w-16 md:h-16"><Image src={cat.icon} alt={cat.name} fill className="object-contain" /></div></div>
                      <p className="text-[10px] md:text-[11px] font-extrabold text-gray-700 uppercase tracking-tight text-center mt-2">{cat.name}</p>
                    </Card>
                  ))}
                </div>
              </div>
            </div>
          )}

          {step >= 2 && (
            <div className="max-w-2xl mx-auto p-4 pt-10 text-center flex flex-col gap-10 items-center">
              <div className="w-full flex flex-col gap-10" style={{ maxWidth: "590px" }}>
                <div className="flex justify-between items-center">
                  {!showManualBox && step === 2 && (
                    <button onClick={() => setStep(1)} className="flex items-center font-bold text-[11px] uppercase text-[#2563eb]"><ArrowLeft className="mr-1 h-3.5 w-3.5" /> Categorías</button>
                  )}
                  <button onClick={resetAll} className="flex items-center font-bold text-[11px] uppercase text-red-500 hover:opacity-80 transition-opacity ml-auto">
                    <RefreshCcw className="mr-1 h-3.5 w-3.5" /> Empezar de nuevo
                  </button>
                </div>

                <div className="text-left animate-in fade-in">
                  <h2 className="text-xl font-extrabold uppercase text-gray-900 mb-6 tracking-tight">¿Qué marca es tu {selectedCategory}?</h2>
                  {selectedBrand ? (
                    <div className="bg-white p-4 rounded-xl border-2 border-[#00984a] flex items-center justify-between">
                      <span className="text-lg font-bold text-gray-800 uppercase">{selectedBrand}</span>
                      <button onClick={() => { setSelectedBrand(""); setSelectedModel(""); setSelectedYear(""); setSelectedVersion(""); setShowManualBox(false); setStep(2); }} className="text-[10px] font-bold text-[#2563eb] uppercase underline">Cambiar</button>
                    </div>
                  ) : (
                    <>
                      <div className="flex flex-wrap justify-center gap-1.5 mb-6">
                        {dynamicTopBrands.map((brand) => (
                          <button key={brand.name} onClick={() => setSelectedBrand(brand.name.toUpperCase())} 
                            className="bg-white rounded-lg border border-gray-100 flex items-center justify-center shadow-sm hover:border-[#00984a] transition-all p-2 h-[78px] w-[78px]">
                            <div className="relative w-8 h-8"><Image src={brand.logo} alt={brand.name} fill className="object-contain" /></div>
                          </button>
                        ))}
                      </div>
                      <div className="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden text-left">
                        <div className="p-4 border-b border-gray-50"><Input placeholder="BUSCAR OTRA MARCA..." className={inputClassName} value={searchBrand} onChange={(e) => setSearchBrand(e.target.value.toUpperCase())} /></div>
                        <div className="divide-y divide-gray-50 max-h-[200px] overflow-y-auto bg-white">
                          {availableBrands.filter(b => b.includes(searchBrand)).map((item) => (
                            <button key={item} onClick={() => setSelectedBrand(item)} className="w-full flex items-center justify-between px-5 py-3 hover:bg-gray-50 font-semibold uppercase text-sm text-gray-700">{item}<ChevronRight className="h-4 w-4" /></button>
                          ))}
                          <button onClick={() => { setShowManualBox(true); setStep(3); scrollTo(reviewSectionRef); }} className="w-full flex items-center justify-between px-5 py-4 bg-orange-50/50 hover:bg-orange-50 font-bold uppercase text-xs text-orange-600 border-t">NO ENCUENTRO MI MARCA <PlusCircle className="h-4 w-4" /></button>
                        </div>
                      </div>
                    </>
                  )}
                </div>

                {selectedBrand && (
                  <div className="text-left animate-in fade-in">
                    <h2 className="text-xl font-extrabold uppercase text-gray-900 mb-4 tracking-tight">Modelo</h2>
                    {selectedModel ? (
                      <div className="bg-white p-4 rounded-xl border-2 border-[#00984a] flex items-center justify-between">
                        <span className="text-lg font-bold text-gray-800 uppercase">{selectedModel}</span>
                        <button onClick={() => { setSelectedModel(""); setSelectedYear(""); setSelectedVersion(""); setShowManualBox(false); setStep(2); }} className="text-[10px] font-bold text-[#2563eb] uppercase underline">Cambiar</button>
                      </div>
                    ) : (
                      <div className="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden text-left">
                        <div className="p-4 border-b border-gray-50"><Input placeholder={`BUSCAR MODELO DE ${selectedBrand}...`} className={inputClassName} value={searchModel} onChange={(e) => setSearchModel(e.target.value.toUpperCase())} /></div>
                        <div className="divide-y divide-gray-50 max-h-[250px] overflow-y-auto bg-white">
                          {availableModels.filter(m => m.includes(searchModel)).map((item) => (
                            <button key={item} onClick={() => { setSelectedModel(item); scrollTo(yearSectionRef); }} className="w-full flex items-center justify-between px-5 py-3 hover:bg-gray-50 font-semibold uppercase text-sm text-gray-700">{item}<ChevronRight className="h-4 w-4 text-gray-300" /></button>
                          ))}
                          <button onClick={() => { setShowManualBox(true); setStep(3); scrollTo(reviewSectionRef); }} className="w-full flex items-center justify-between px-5 py-4 bg-orange-50/50 hover:bg-orange-50 font-bold uppercase text-xs text-orange-600 border-t">NO ENCUENTRO MI MODELO <PlusCircle className="h-4 w-4" /></button>
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {selectedModel && (
                  <div ref={yearSectionRef} className="text-left animate-in fade-in">
                    <h2 className="text-xl font-extrabold uppercase text-gray-900 mb-6 tracking-tight">Año</h2>
                    {selectedYear ? (
                      <div className="bg-white p-4 rounded-xl border-2 border-[#00984a] flex items-center justify-between">
                        <span className="text-lg font-bold text-gray-800 uppercase">{selectedYear}</span>
                        <button onClick={() => { setSelectedYear(""); setSelectedVersion(""); setShowManualBox(false); setStep(2); }} className="text-[10px] font-bold text-[#2563eb] uppercase underline">Cambiar</button>
                      </div>
                    ) : (
                      <div className="grid grid-cols-4 sm:grid-cols-6 gap-2">
                        {YEARS.map((y) => (
                          <button key={y} onClick={() => { setSelectedYear(y); scrollTo(versionSectionRef); }} className="py-3 rounded-lg border bg-white text-gray-600 border-gray-200 font-bold text-sm hover:border-[#00984a] transition-all">{y}</button>
                        ))}
                      </div>
                    )}
                  </div>
                )}

                {selectedYear && (
                  <div ref={versionSectionRef} className="text-left animate-in fade-in">
                    <h2 className="text-xl font-extrabold uppercase text-gray-900 mb-6 tracking-tight">Versión</h2>
                    {selectedVersion ? (
                      <div className="bg-white p-4 rounded-xl border-2 border-[#00984a] flex items-center justify-between">
                        <span className="text-lg font-bold text-gray-800 uppercase">{selectedVersion}</span>
                        <button onClick={() => { setSelectedVersion(""); setStep(3); setShowManualBox(false); scrollTo(versionSectionRef); }} className="text-[10px] font-bold text-[#2563eb] uppercase underline">Cambiar</button>
                      </div>
                    ) : (
                      <div className="bg-white rounded-xl shadow-md border border-gray-100 overflow-hidden text-left">
                        <div className="p-4 border-b border-gray-50"><Input placeholder="BUSCAR VERSIÓN..." className={inputClassName} value={searchVersion} onChange={(e) => setSearchVersion(e.target.value.toUpperCase())} /></div>
                        <div className="divide-y divide-gray-50 max-h-[250px] overflow-y-auto bg-white">
                          {availableVersions.filter(v => v.includes(searchVersion)).map((item) => (
                            <button key={item} onClick={() => { setSelectedVersion(item); setStep(3); scrollTo(reviewSectionRef); }} className="w-full flex items-center justify-between px-5 py-3 hover:bg-gray-50 font-semibold uppercase text-sm text-gray-700">{item}<ChevronRight className="h-4 w-4 text-gray-300" /></button>
                          ))}
                          <button onClick={() => { setShowManualBox(true); setStep(3); scrollTo(reviewSectionRef); }} className="w-full flex items-center justify-between px-5 py-4 bg-orange-50/50 hover:bg-orange-50 font-bold uppercase text-xs text-orange-600 border-t">NO ENCUENTRO MI VERSIÓN <PlusCircle className="h-4 w-4" /></button>
                        </div>
                      </div>
                    )}
                  </div>
                )}
                
                {!showManualBox && (
                  <button onClick={() => { setShowManualBox(true); setStep(3); scrollTo(reviewSectionRef); }} className="flex items-center justify-center gap-2 font-bold text-[#2563eb] text-[11px] uppercase mt-4">
                    <PlusCircle className="h-4 w-4" /> Es un clásico / Cargar Manual
                  </button>
                )}
              </div>

              {(showManualBox || selectedVersion) && (
                <div ref={reviewSectionRef} className="w-full max-w-[590px] animate-in fade-in">
                  <div className={`bg-white rounded-2xl shadow-xl border-2 border-[#00984a] p-8 text-left transition-all ${step > 3 ? "opacity-60" : ""}`}>
                    <h2 className="text-lg font-bold text-gray-900 uppercase tracking-tight">Características Principales</h2>
                    <p className="text-[11px] text-gray-400 mt-1 mb-10 tracking-tight">( Completá la información manual )</p>
                    <div className="grid grid-cols-2 gap-x-8 gap-y-8">
                      <div className="space-y-2">
                        <label className="text-[10px] font-bold text-gray-300 uppercase tracking-wider">Marca</label>
                        <Input className={manualInputClass} value={selectedBrand} onChange={(e) => setSelectedBrand(e.target.value.toUpperCase())} />
                      </div>
                      <div className="space-y-2">
                        <label className="text-[10px] font-bold text-gray-300 uppercase tracking-wider">Modelo</label>
                        <Input className={manualInputClass} value={selectedModel} onChange={(e) => setSelectedModel(e.target.value.toUpperCase())} />
                      </div>
                      <div className="space-y-2">
                        <label className="text-[10px] font-bold text-gray-300 uppercase tracking-wider">Año</label>
                        <Input className={manualInputClass} value={selectedYear} onChange={(e) => setSelectedYear(e.target.value.toUpperCase())} placeholder="AÑO" />
                      </div>
                      <div className="space-y-2">
                        <label className="text-[10px] font-bold text-gray-300 uppercase tracking-wider">Versión</label>
                        <Input className={manualInputClass} value={selectedVersion} onChange={(e) => setSelectedVersion(e.target.value.toUpperCase())} placeholder="VERSIÓN" />
                      </div>
                    </div>
                    {step === 3 && (
                      <div className="mt-12 flex justify-end">
                        <button onClick={() => { setStep(4); scrollTo(kmSectionRef); }} className="bg-[#00984a] text-white px-14 py-4 rounded-xl font-bold uppercase text-sm shadow-md active:scale-95 tracking-tight">
                          Confirmar
                        </button>
                      </div>
                    )}
                  </div>
                </div>
              )}

              {step >= 4 && (
                <section ref={kmSectionRef} className="w-full max-w-[590px] animate-in fade-in">
                  <div className={`bg-white rounded-2xl shadow-xl border-2 border-[#00984a] p-8 text-left transition-all ${step > 4 ? "opacity-60" : ""}`}>
                    <h3 className="text-base font-bold text-gray-800 uppercase mb-4 tracking-tight">Kilometraje</h3>
                    <div className="relative">
                      <Input 
                        className="h-14 font-bold text-lg bg-[#f4f6f8] !text-black border-none focus:!border-[#00984a] focus:!ring-0 outline-none" 
                        value={km} 
                        onChange={handleKmChange} 
                        placeholder="0" 
                      />
                      <span className="absolute right-4 top-1/2 -translate-y-1/2 font-bold text-gray-400">KM</span>
                    </div>
                    {step === 4 && (
                      <button onClick={() => setStep(5)} className="w-full mt-6 bg-[#00984a] text-white py-4 rounded-xl font-bold uppercase shadow-xl tracking-tight">
                        CONFIRMAR E IR A FOTOS
                      </button>
                    )}
                  </div>
                </section>
              )}
            </div>
          )}
        </main>
      </div>
    </SidebarProvider>
  );
}